POSTGRES_URL=postgres://user:password@host:5432/database
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database

# --- Adjuntos de incidencias (foto en chat + archivo del ticket) ---
# Proveedor de almacenamiento: vercel_blob (defecto) | local_fs
# ATTACHMENT_STORAGE_PROVIDER=vercel_blob
#
# Vercel Blob (subida servidor con @vercel/blob). En Vercel suele inyectarse al crear el Blob Store:
# BLOB_READ_WRITE_TOKEN=
#
# local_fs: ruta persistente (volumen, disco). Si no se define, en Lambda/Vercel se usa /tmp (efímero).
# INCIDENT_ATTACHMENT_ROOT=/var/data/ventanilla-attachments
# INCIDENT_ATTACHMENTS_USE_TMP=1

# LLM interpreter configuration (server-side only)
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_MODEL_INTERPRETER=gpt-4.1-mini
APP_DEFAULT_LOCALE=es

# Optional: chatbot debug (web channel)
# CHATBOT_DEBUG=1

# WhatsApp Cloud API (Meta) — webhook + outbound messages
# String you choose; must match Meta webhook "Verify token" field
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-string
# From Meta app → WhatsApp → API Setup (temporary or long-lived token)
WHATSAPP_ACCESS_TOKEN=
# Phone number ID used in Graph API paths (.../PHONE_NUMBER_ID/messages)
WHATSAPP_PHONE_NUMBER_ID=
# App Secret (Meta app → Settings → Basic) — required for X-Hub-Signature-256 in production
WHATSAPP_APP_SECRET=
# Optional: WhatsApp Business Account ID (not required by current webhook code)
# WHATSAPP_BUSINESS_ACCOUNT_ID=
