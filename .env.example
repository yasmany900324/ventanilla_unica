POSTGRES_URL=postgres://user:password@host:5432/database
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database

# --- Adjuntos de incidencias (foto en chat + archivo del ticket) ---
# Proveedor de almacenamiento: vercel_blob (defecto) | local_fs
# ATTACHMENT_STORAGE_PROVIDER=vercel_blob
#
# Vercel Blob (subida servidor con @vercel/blob). En Vercel suele inyectarse al crear el Blob Store:
# BLOB_READ_WRITE_TOKEN=
# Si el Blob Store es privado (no público), obligatorio:
# ATTACHMENT_VERCEL_BLOB_ACCESS=private
#
# local_fs: ruta persistente (volumen, disco). Si no se define, en Lambda/Vercel se usa /tmp (efímero).
# INCIDENT_ATTACHMENT_ROOT=/var/data/ventanilla-attachments
# INCIDENT_ATTACHMENTS_USE_TMP=1

# LLM interpreter configuration (server-side only)
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_MODEL_INTERPRETER=gpt-4.1-mini
# Logs JSON detallados de cada llamada OpenAI en consola (Vercel Runtime Logs).
# Si no se define: activo en development y Vercel preview; en production solo con true.
# OPENAI_VERBOSE_LOGS=true
APP_DEFAULT_LOCALE=es

# Opcional: versión visible en el pie del portal (sobrescribe config/appVersion.js al build)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: chatbot debug (web channel)
# CHATBOT_DEBUG=1

# WhatsApp Cloud API (Meta) — webhook + outbound messages
# String you choose; must match Meta webhook "Verify token" field
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-string
# From Meta app → WhatsApp → API Setup (temporary or long-lived token)
WHATSAPP_ACCESS_TOKEN=
# Phone number ID used in Graph API paths (.../PHONE_NUMBER_ID/messages)
WHATSAPP_PHONE_NUMBER_ID=
# App Secret (Meta app → Settings → Basic) — required for X-Hub-Signature-256 in production
WHATSAPP_APP_SECRET=
# Optional: WhatsApp Business Account ID (not required by current webhook code)
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- WhatsApp: audio entrante (speech-to-text, servidor) ---
# Proveedor: vacío u "openai_whisper" usa OpenAI Whisper; "none" desactiva STT (el usuario recibe aviso al mandar audio).
# STT_PROVIDER=
# Clave para STT (si no se define, se reutiliza OPENAI_API_KEY)
# STT_API_KEY=
# Modelo de transcripción (OpenAI)
# STT_MODEL=whisper-1
# Límite de bytes descargados desde WhatsApp antes de transcribir (defecto ~20 MB)
# WHATSAPP_AUDIO_MAX_BYTES=20971520
# Timeouts (ms) para descarga Graph y para llamada STT
# WHATSAPP_AUDIO_DOWNLOAD_TIMEOUT_MS=25000
# WHATSAPP_STT_TIMEOUT_MS=55000
# Logs extra de STT (texto transcrito truncado en consola). 1 o true para activar.
# WHATSAPP_AUDIO_STT_DEBUG=1

# --- Camunda 8 SaaS (Orchestration Cluster REST v2, sin workers) ---
# Credenciales desde Console → clúster → API → cliente (Orchestration Cluster API).
# CAMUNDA_OAUTH_URL suele ser https://login.cloud.camunda.io/oauth/token
# CAMUNDA_TOKEN_AUDIENCE: en el archivo descargado aparece como ZEEBE_TOKEN_AUDIENCE (p. ej. zeebe-api).
# CAMUNDA_REST_ADDRESS o ZEEBE_REST_ADDRESS: base REST con /v2, o sin /v2 (se normaliza).
# Alternativa: definir CAMUNDA_CLUSTER_REGION + CAMUNDA_CLUSTER_ID (URL pública SaaS).
# CAMUNDA_CLIENT_ID=
# CAMUNDA_CLIENT_SECRET=
# CAMUNDA_OAUTH_URL=
# CAMUNDA_TOKEN_AUDIENCE=
# ZEEBE_TOKEN_AUDIENCE=
# CAMUNDA_REST_ADDRESS=
# ZEEBE_REST_ADDRESS=
# CAMUNDA_CLUSTER_ID=
# CAMUNDA_CLUSTER_REGION=
# BPMN process id (processDefinitionId) desplegado en el clúster:
# Nota: ahora se prioriza `camunda_process_id` definido por cada ítem en
# `chatbot_procedure_catalog`. Estas variables quedan como fallback temporal.
# CAMUNDA_PROCESS_ID_INCIDENT=seguimiento_incidencia
# CAMUNDA_PROCESS_ID_TRAMITE=seguimiento_tramite
