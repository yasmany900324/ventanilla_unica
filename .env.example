POSTGRES_URL=postgres://user:password@host:5432/database
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database

# Dialogflow ES project configuration (server-side only)
DIALOGFLOW_PROJECT_ID=your-gcp-project-id
DIALOGFLOW_LANGUAGE_CODE=es

# Service account credentials used by the server to call Dialogflow.
# IMPORTANT: keep these values private and never expose them in browser code.
GOOGLE_CLIENT_EMAIL=dialogflow-service-account@your-gcp-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
